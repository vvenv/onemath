  "topic": "方阵问题",
  "question": "四年级同学排成一个实心方阵进行广播操表演，最外层每边站了12人。请问这个方阵一共有多少人？最外层一共有多少人？",
  "solutions": [
    {
      "key": "layer",
      "label": "分层计算",
      "steps": [
        "实心方阵总人数：每边人数 × 每边人数 = 12 × 12 = 144（人）。",
        "最外层人数计算（方法一）：(每边人数 − 1) × 4 = (12 − 1) × 4 = 11 × 4 = 44（人）。",
        "最外层人数计算（方法二）：每边人数 × 4 − 4 = 12 × 4 − 4 = 48 − 4 = 44（人）。"
      ],
      "scenes": [
        {
          "kind": "lattice",
          "lattice": { "rows": 12, "cols": 12, "tone": "primary" },
          "caption": "12×12 实心方阵，总人数144人"
        }
      ]
    }
  ],
