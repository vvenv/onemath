  "id": "10011",
  "title": "差倍问题·基本差倍",
  "grade": "三年级",
  "module": "word",
  "difficulty": "基础",
  "question": "学校合唱队的人数比舞蹈队多24人，合唱队人数是舞蹈队的3倍。合唱队和舞蹈队各有多少人？",
  "solutions": [
    {
      "key": "diff_multiple",
      "label": "差倍·份数法",
      "steps": [
        "舞蹈队看作 1 份，合唱队就是 3 份。",
        "两队份数差：3 − 1 = 2 份，对应 24 人。",
        "1 份 = 24 ÷ 2 = 12（人）→ 舞蹈队 12 人。",
        "合唱队：12 × 3 = 36（人）。"
      ],
      "scenes": [
        {
          "kind": "compare-bars",
          "rows": [
            {
              "label": "舞蹈队 1 份",
              "value": 12,
              "max": 36,
              "tone": "muted"
            },
            {
              "label": "合唱队 3 份",
              "value": 36,
              "max": 36,
              "tone": "primary",
              "marker": true
            }
          ],
          "caption": "相差的 2 份 = 24 人 ⇒ 1 份 = 12 人"
        },
        {
          "kind": "result-badges",
          "items": [
            {
              "icon": "💃",
              "count": 12,
              "label": "舞蹈队"
            },
            {
              "icon": "🎤",
              "count": 36,
              "label": "合唱队"
            }
          ],
          "caption": "差 24 ✓，倍数 3 ✓"
        }
      ]
    },
    {
      "key": "equation",
      "label": "方程法",
      "steps": [
        "设舞蹈队 x 人，则合唱队 3x 人。",
        "两队人数差：3x − x = 24 ⇒ 2x = 24 ⇒ x = 12。",
        "舞蹈队 12 人，合唱队 3 × 12 = 36 人。"
      ],
      "scenes": [
        {
          "kind": "equation-list",
          "rows": [
            {
