{
  "$schema": "../problem.schema.json",
  "id": "10016",
  "title": "盈亏问题·一盈一亏",
  "grade": "四年级",
  "module": "word",
  "question": "老师给小朋友们分糖果。如果每人分5颗，则少3颗；如果每人分4颗，则多2颗。请问有多少个小朋友？有多少颗糖果？",
  "solutions": [
    {
      "key": "formula",
      "label": "公式法",
      "steps": [
        "盈亏总额：盈 + 亏 = 2 + 3 = 5（颗）。",
        "两次分配差：5 − 4 = 1（颗）。",
        "小朋友人数：盈亏总额 ÷ 分配差 = 5 ÷ 1 = 5（个）。",
        "糖果总数：5 × 5 − 3 = 22（颗），或 4 × 5 + 2 = 22（颗）。"
      ],
      "scenes": [
        {
          "kind": "heads-split",
          "left": {
            "count": 3,
            "ticks": [{ "count": 1, "tone": "accent" }],
            "tone": "accent",
            "caption": "方案一亏 3 颗",
            "captionTone": "primary"
          },
          "right": {
            "count": 2,
            "ticks": [{ "count": 1 }],
            "caption": "方案二盈 2 颗"
          },
          "caption": "盈亏总额 = 2 + 3 = 5"
        },
        {
          "kind": "compare-bars",
          "rows": [
            {
              "label": "方案一每人 5",
              "value": 5,
              "max": 5,
              "tone": "primary"
            },
            {
              "label": "方案二每人 4",
              "value": 4,
              "max": 5,
              "tone": "muted",
              "marker": true
            }
          ],
          "caption": "两方案每人相差 5 − 4 = 1 颗"
        },
        {
          "kind": "equation-list",
          "rows": [
            {
              "lhs": "人数",
              "rhs": "盈亏总额 ÷ 分配差 = 5 ÷ 1 = 5",
              "status": "keep"
            },
            { "lhs": "糖果", "rhs": "5×5 − 3 = 22", "note": "或 4×5 + 2 = 22" }
          ],
          "caption": "代入公式求人数与糖果总数"
        },
        {
          "kind": "result-badges",
          "items": [
            { "icon": "👧", "count": 5, "label": "小朋友" },
            { "icon": "🍬", "count": 22, "label": "糖果" }
          ],
          "caption": "验证：5×5 − 3 = 22 ✓"
        }
      ]
    },
    {
      "key": "equation",
      "label": "方程法",
      "steps": [
        "设小朋友 x 人。",
        "糖果总数不变：5x − 3 = 4x + 2。",
        "移项：5x − 4x = 2 + 3 ⇒ x = 5。",
        "糖果：5 × 5 − 3 = 22 颗。"
      ],
      "scenes": [
        {
          "kind": "equation-list",
          "rows": [
            { "lhs": "5x − 3", "rhs": "4x + 2", "note": "糖果数相同" },
            { "lhs": "5x − 4x", "rhs": "2 + 3", "status": "keep" },
            { "lhs": "x", "rhs": "5", "status": "keep" }
          ],
          "caption": "解方程得人数"
        }
      ]
    }
  ],
  "variant": {
    "question": "学校安排宿舍，如果每间住6人，则少2个床位；如果每间住5人，则多出3个床位。问有多少间宿舍？多少人？",
