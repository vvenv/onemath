{
  "$schema": "../problem.schema.json",
  "id": "10089",
  "title": "五阶幻方·幻和求值",
  "grade": "五年级",
  "module": "misc",
  "difficulty": "进阶",
  "question": "把 1, 2, 3, …, 25 这 25 个数字各用一次，填入 5 × 5 方格中，使每一行、每一列、两条对角线上 5 个数之和都相等。问：这个公共和（幻和）是多少？",
  "figures": [
    {
      "svg": "<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 220 220' font-family='sans-serif' font-size='12'><g fill='#fdfefe' stroke='#2E86C1'><rect x='20' y='20' width='180' height='180'/><g><line x1='56' y1='20' x2='56' y2='200'/><line x1='92' y1='20' x2='92' y2='200'/><line x1='128' y1='20' x2='128' y2='200'/><line x1='164' y1='20' x2='164' y2='200'/><line x1='20' y1='56' x2='200' y2='56'/><line x1='20' y1='92' x2='200' y2='92'/><line x1='20' y1='128' x2='200' y2='128'/><line x1='20' y1='164' x2='200' y2='164'/></g></g></svg>",
      "caption": "空的 5×5 方格",
      "alt": "空的 5×5 方格"
    }
  ],
  "solutions": [
    {
      "key": "sum",
      "label": "累加法",
      "steps": [
        "分析：5 行把 1–25 每个数字各覆盖一次，因此 5 行之和等于 1+2+…+25。",
        "1+2+…+25 = (1+25) × 25 / 2 = 325（首尾配对：1+25, 2+24, … , 13 单，共 12 对 × 26 + 13 = 325）。",
        "设幻和为 S，则 5S = 325，得 S = 65。"
      ],
      "scenes": [
        {
          "kind": "equation-list",
          "rows": [
            { "lhs": "1+2+…+25", "rhs": "(1+25)·25/2 = 325" },
            { "lhs": "5S", "rhs": "325" },
            { "lhs": "S", "rhs": "65", "status": "keep", "badge": "幻和" }
          ]
        }
      ]
    },
    {
      "key": "middle",
      "label": "等差数列法",
      "steps": [
        "分析：1 到 25 是等差数列，中位数为 13（第 13 大）。",
        "n 阶幻方（n 为奇数）填 1 到 n² 时，幻和 = n × 中位数 = n × (n²+1)/2。",
        "这里 n=5：S = 5 × (25+1)/2 = 5 × 13 = 65。"
      ],
      "scenes": [
        {
          "kind": "result-badges",
          "items": [{ "icon": "🎯", "count": 65, "label": "幻和" }]
        }
      ]
    }
  ],
  "variant": {
    "question": "n 阶幻方（n 为奇数）填入 1 到 n²，问 n=7 时幻和等于多少？",
    "fields": [{ "key": "sum", "label": "幻和", "type": "number" }],
    "answer": { "sum": 175 },
    "hint": "公式：S = n × (n²+1) / 2。n=7 时 S = 7 × 50/2 = 175。"
  },
  "tags": [
