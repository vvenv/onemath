            { "label": "右列最高", "value": 2, "max": 3, "tone": "primary" }
          ],
          "caption": "正视图：左列=3、中列=1、右列=2（每列的最高堆数）"
        },
        {
          "kind": "number-grid",
          "rows": 3,
