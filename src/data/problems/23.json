          "cells": [
            { "row": 0, "col": 0, "value": 3, "tone": "primary" },
            { "row": 0, "col": 1, "value": 1, "tone": "default" },
            { "row": 0, "col": 2, "value": 2, "tone": "primary" },
            { "row": 1, "col": 0, "value": 1, "tone": "default" },
            { "row": 1, "col": 1, "value": 1, "tone": "default" },
            { "row": 1, "col": 2, "value": 1, "tone": "default" },
            { "row": 2, "col": 0, "value": 1, "tone": "default" },
            { "row": 2, "col": 1, "value": 1, "tone": "default" },
            { "row": 2, "col": 2, "value": 1, "tone": "default" }
          ],
          "rowLabel": "后 ← → 前",
          "colLabel": "左 ← → 右",
          "caption": "标数：每列只需一个格子达到最大高度（高亮），其余填 1"
        },
        {
          "kind": "result-badges",
          "items": [
            { "icon": "🧊", "count": 5, "label": "左列 3+1+1" },
            { "icon": "🧊", "count": 3, "label": "中列 1+1+1" },
            { "icon": "🧊", "count": 4, "label": "右列 2+1+1" }
          ],
          "separator": "+",
          "caption": "按列求和：5 + 3 + 4 = 12"
        },
