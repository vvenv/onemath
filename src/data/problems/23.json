            { "row": 1, "col": 2, "value": "■", "tone": "muted" },
            { "row": 2, "col": 0, "value": "■", "tone": "muted" },
            { "row": 2, "col": 1, "value": "■", "tone": "muted" },
            { "row": 2, "col": 2, "value": "■", "tone": "muted" }
          ],
          "rowLabel": "后 ← → 前",
          "colLabel": "左 ← → 右",
          "caption": "俯视图：3×3 共 9 个位置都有方块（地基）"
        },
        {
          "kind": "compare-bars",
