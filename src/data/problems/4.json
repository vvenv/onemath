            { "icon": "⛺", "count": 21, "label": "帐篷" },
            { "icon": "🧑‍🚀", "count": 119, "label": "队员" }
          ],
          "caption": "人数：5 × 21 + 14 = 119 ｜ 7 × 21 − 28 = 119 ✓"
        }
      ]
    },
    {
      "key": "equation",
      "label": "方程法",
      "steps": [
        "设有 x 顶帐篷。",
        "根据人数不变列方程：5x + 14 = 7(x − 4)。",
        "解方程：5x + 14 = 7x − 28。",
        "移项：14 + 28 = 7x − 5x ⇒ 42 = 2x ⇒ x = 21。",
        "人数：5 × 21 + 14 = 119。"
      ]
    }
  ],
