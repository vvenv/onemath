  "question": "计算：999 + 99 + 9",
  "figures": [
    {
      "svg": "<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 400 80'><text x='20' y='45' font-size='28' font-family='monospace' fill='#333'>999 + 99 + 9 = ?</text><text x='20' y='75' font-size='14' fill='#888'>观察：每个数都接近整十、整百、整千</text></svg>",
      "caption": "凑整法：把接近整十、整百、整千的数先凑整，再调整",
      "alt": "算式 999 + 99 + 9"
    }
  ],
  "solutions": [
    {
      "key": "rounding",
      "label": "凑整法",
      "steps": [
        "观察发现 999、99、9 分别接近 1000、100、10。",
        "把每个数凑成整数：999 = 1000 − 1，99 = 100 − 1，9 = 10 − 1。",
        "先加整数部分：1000 + 100 + 10 = 1110。",
        "再减去多算的：1110 − 1 − 1 − 1 = 1110 − 3 = 1107。"
      ],
      "scenes": [
        {
          "kind": "equation-list",
          "rows": [
