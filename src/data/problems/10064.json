              "lhs": "向上步数",
              "rhs": "4 − 1 = 3"
            },
            {
              "lhs": "路径数",
              "rhs": "C(7, 3) = 35",
              "badge": "结论"
            }
          ],
          "caption": "把最短路径看作 7 步中选 3 步向上"
